{
  "template_name": "lightweight-generic-harness-template",
  "source_scoreboard": "experiments/011-evaluation-harness/artifacts/evaluation-scoreboard.json",
  "included_default_patterns": [
    "short-top-level-map",
    "current-singular-guidance",
    "custom-architecture-rule",
    "checked-in-durable-context"
  ],
  "excluded_patterns": [
    {
      "pattern": "checked-in-execution-plan",
      "tier": "conditional",
      "reason": "Useful for longer work, but redundant for the light default when Codex already carries session flow."
    },
    {
      "pattern": "branch-per-task-worktrees",
      "tier": "conditional",
      "reason": "Still useful, but better kept as repo workflow advice instead of mandatory base-template structure."
    }
  ],
  "required_files": [
    ".gitignore",
    "AGENTS.md",
    "README.md",
    "docs/project.md",
    "docs/architecture.md",
    "docs/task.md",
    "docs/log.md",
    "checks/check-top-level-guidance.py",
    "checks/check-architecture.py",
    "checks/architecture-rules.json"
  ],
  "required_top_level_paths": [
    "README.md",
    "docs/project.md",
    "docs/architecture.md",
    "docs/task.md",
    "docs/log.md"
  ],
  "top_level_pack_files": [
    "AGENTS.md",
    "README.md"
  ],
  "top_level_word_budget": 220,
  "required_project_sections": [
    "## Purpose",
    "## Current shape",
    "## Constraints",
    "## Key paths"
  ],
  "required_architecture_sections": [
    "## Boundaries",
    "## Stable interfaces",
    "## Risk hotspots",
    "## Rule hooks"
  ],
  "required_task_sections": [
    "## Current task",
    "## Scope",
    "## Verify",
    "## Done when",
    "## Blockers"
  ],
  "required_log_sections": [
    "## Entry template",
    "## Entries"
  ],
  "placeholder_token": "[TO_FILL]",
  "placeholder_docs": {
    "docs/project.md": [
      "## Purpose",
      "## Current shape",
      "## Constraints",
      "## Key paths"
    ],
    "docs/architecture.md": [
      "## Boundaries",
