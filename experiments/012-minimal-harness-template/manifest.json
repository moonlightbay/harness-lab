{
  "template_name": "generic-harness-template",
  "source_scoreboard": "experiments/011-evaluation-harness/artifacts/evaluation-scoreboard.json",
  "included_default_patterns": [
    "short-top-level-map",
    "current-singular-guidance",
    "checked-in-execution-plan",
    "custom-architecture-rule",
    "branch-per-task-worktrees"
  ],
  "excluded_patterns": [
    {
      "pattern": "role-divided-workflow",
      "tier": "conditional",
      "reason": "Useful when audit trail matters, but too expensive for the base template."
    },
    {
      "pattern": "remediation-oriented-live-feedback",
      "tier": "needs-more-data",
      "reason": "Keep out of the base template until the live repair benefit is clearer."
    }
  ],
  "required_files": [
    ".gitignore",
